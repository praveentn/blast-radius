# A file like this sits in thousands of working trees. Nobody thinks of it as
# part of the agent's permission model. It is.
#
# Rename to .env to reproduce the scan in the README.
#
# The interesting line is the last one. It is named for domain management, so
# every human who reads it assumes the scope is domains. The provider does not
# scope it that way.

NODE_ENV=staging
LOG_LEVEL=debug

DATABASE_URL=postgres://app:hunter2@db.internal:5432/app_staging

# Left here by whoever set up the custom domain, eighteen months ago.
RAILWAY_DOMAIN_TOKEN=rw_live_REDACTED_EXAMPLE_VALUE_NOT_A_REAL_TOKEN
